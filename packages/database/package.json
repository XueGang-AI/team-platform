{
  "name": "@team-platform/database",
  "version": "1.0.0",
  "private": true,
  "description": "控制面 Prisma schema、迁移与生成脚本归属地。生成产物输出到 apps/api/src/generated/prisma，由 API 直接消费。",
  "scripts": {
    "build": "pnpm run db:generate",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "db:push": "prisma db push --schema prisma/schema.prisma",
    "lint": "echo 'schema-only package: nothing to lint'",
    "typecheck": "echo 'schema-only package: nothing to typecheck'"
  },
  "devDependencies": {
    "@prisma/config": "^7.8.0",
    "prisma": "^7.8.0"
  }
}
