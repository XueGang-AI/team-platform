# ---- 运行环境 ----
NODE_ENV=development
ENVIRONMENT=dev
LOG_LEVEL=info

# ---- API ----
SERVICE_NAME=team-platform-api
API_VERSION=1.0.0
API_HOST=0.0.0.0
API_PORT=3201

# ---- Web（管理后台）----
WEB_PORT=3200
# 浏览器侧默认走管理后台同源代理。这样用户只需要打开 Web 入口。
WEB_API_BASE_URL=/api/platform
# Next.js 代理访问平台 API 的内部上游地址。
PLATFORM_API_INTERNAL_URL=http://localhost:3201

# ---- PostgreSQL（本地开发，仅占位值，非生产密钥）----
# 使用通用 PostgreSQL 服务，宿主端口 15432，数据库名 team_platform。
DATABASE_URL=postgresql://team_platform:team_platform@127.0.0.1:15432/team_platform?schema=public

# ---- Redis（本地开发）----
# 使用通用 Redis 服务，宿主端口 16379，键前缀 team_platform:。
REDIS_URL=redis://127.0.0.1:16379
REDIS_KEY_PREFIX=team_platform:

# ---- 健康检查 SSRF 防护 ----
# 允许主动探测的主机（host 或 host:port），逗号分隔。
# 本地开发允许平台自身；生产环境默认不得允许任意目标。
HEALTH_CHECK_ALLOWED_HOSTS=localhost:3100,localhost:3201
# 单次健康探测超时（毫秒）
HEALTH_CHECK_TIMEOUT_MS=3000
# 健康探测最大并发
HEALTH_CHECK_MAX_CONCURRENCY=5

# ---- Auth（本地开发，仅占位值，非生产密钥）----
# Phase 3 本地邮箱登录使用 HMAC Bearer token；生产环境必须替换。
AUTH_TOKEN_SECRET=team-platform-local-dev-secret
