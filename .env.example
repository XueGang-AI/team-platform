# ---- 运行环境 ----
NODE_ENV=development
ENVIRONMENT=dev
LOG_LEVEL=info

# ---- API ----
SERVICE_NAME=team-platform-api
API_VERSION=1.0.0
API_HOST=0.0.0.0
API_PORT=3001

# ---- Web（管理后台）----
WEB_PORT=3000
# Web 调用 API 的基础地址
WEB_API_BASE_URL=http://localhost:3001

# ---- PostgreSQL（本地开发，仅占位值，非生产密钥）----
# 宿主端口 5433（容器内 5432），避开常见本机已安装的 PostgreSQL(5432) 冲突
DATABASE_URL=postgresql://team_platform:team_platform@localhost:5433/team_platform?schema=public

# ---- Redis（本地开发）----
# 宿主端口 6380（容器内 6379），避开常见本机已安装的 Redis(6379) 冲突
REDIS_URL=redis://localhost:6380
