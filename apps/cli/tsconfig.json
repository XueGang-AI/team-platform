{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "Node16",
    "moduleResolution": "Node16",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "rootDir": "src",
    "outDir": "dist",
    "types": ["node"],
    "declaration": false,
    "declarationMap": false,
    "sourceMap": true,
    "isolatedModules": false,
    "verbatimModuleSyntax": false
  },
  "include": ["src"]
}
